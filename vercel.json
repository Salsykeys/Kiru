{
  "version": 2,
  "builds": [
    {
      "src": "backend-pos/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend-pos/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "functions": {
    "backend-pos/index.js": {
      "region": "bom1"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend-pos/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "backend-pos/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-pos/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "frontend-pos/index.html"
    }
  ]
}
