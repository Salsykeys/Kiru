
# DATABASE
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED
DATABASE_URL="mysql://user:password@host:port/defaultdb?ssl-mode=REQUIRED"

# JWT
# Random secret key untuk signing JWT token
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your_jwt_secret_here"

# MIDTRAN
# Dapatkan key di: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY="Mid-server-xxxxxxxxxxxxxxxxxxxx"
MIDTRANS_CLIENT_KEY="Mid-client-xxxxxxxxxxxxxxxxxxxx"
# Set ke true jika sudah production
MIDTRANS_IS_PRODUCTION=false

# CLOUDINARY (untuk upload gambar produk & kategori)
# Dapatkan di: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
